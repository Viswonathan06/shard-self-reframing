#!/usr/bin/bash
# Full pipeline for Phi-4 on both DNA and LinguaSafe:
#   Stage 1: P1→P2 reframing  (DNA + LinguaSafe)
#   Stage 2: Refinement O2    (DNA + LinguaSafe)
#   Stage 3: Judge O1 vs O2   (DNA + LinguaSafe, Gemma-4)
#
# O1 baselines are assumed to already exist (generated by job_baseline_phi4.slurm).
#
# Usage:
#   sbatch scripts/slurm/job_phi4_full_pipeline.slurm

#SBATCH -n 1
#SBATCH --cpus-per-task=16
#SBATCH -p a6000
#SBATCH --qos=gpu_access
#SBATCH --gres=gpu:2
#SBATCH --time=48:00:00
#SBATCH --job-name=phi4_full_pipeline
#SBATCH --output=$PROJECT_ROOT/logs/phi4_full_pipeline_%j.out
#SBATCH --error=$PROJECT_ROOT/logs/phi4_full_pipeline_%j.err

set -euo pipefail

ROOT="$PROJECT_ROOT"
cd "$ROOT"
mkdir -p logs

source ~/.bashrc 2>/dev/null || true
export ROOT_DIR="$ROOT"
export PYTHONPATH="${ROOT}"
export PYTHONUNBUFFERED=1
export HF_HOME=/playpen/huggingface
export HF_HUB="${HF_HOME}/hub"
export USE_LOCAL_MODEL=true
export VLLM_ONLY=1
export VLLM_TRUST_REMOTE_CODE=1
export PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True

PYTHON="$CONDA_PREFIX/envs/vllm-serve/bin/python"

# ── Model resolution helper (download if not present) ─────────────────────────
ensure_model() {
    local repo_id="$1"
    local path
    path=$("$PYTHON" -c "
from huggingface_hub import snapshot_download
print(snapshot_download(repo_id='$repo_id', cache_dir='${HF_HUB}', local_files_only=True))
" 2>/dev/null || true)
    echo "$path"
}

# ── Phi-4 model path ──────────────────────────────────────────────────────────
PHI4_PATH=$(find "${HF_HUB}/models--microsoft--phi-4/snapshots" -maxdepth 1 -mindepth 1 -type d 2>/dev/null | sort -r | head -1 || true)
if [[ ! -f "${PHI4_PATH}/config.json" ]]; then
    echo "Phi-4 not found in /playpen — resolving..."
    PHI4_PATH=$(ensure_model "microsoft/phi-4")
fi
[[ -f "${PHI4_PATH}/config.json" ]] || { echo "ERROR: Could not resolve Phi-4 path"; exit 1; }
echo "Phi-4: ${PHI4_PATH}"

# ── Gemma-4 judge path ────────────────────────────────────────────────────────
GEMMA4_PATH=$(find "${HF_HUB}/models--google--gemma-4-31B-it/snapshots" -maxdepth 1 -mindepth 1 -type d 2>/dev/null | sort -r | head -1 || true)
if [[ ! -f "${GEMMA4_PATH}/config.json" ]]; then
    echo "Gemma-4 not found in /playpen — resolving..."
    GEMMA4_PATH=$(ensure_model "google/gemma-4-31B-it")
fi
[[ -f "${GEMMA4_PATH}/config.json" ]] || { echo "ERROR: Could not resolve Gemma-4 path"; exit 1; }
echo "Gemma-4: ${GEMMA4_PATH}"

# ── Paths ─────────────────────────────────────────────────────────────────────
DNA_JSONL="dataset/donotanswer_no_outputs.jsonl"
LS_CSV="dataset/linguasafe.csv"
GUIDELINES_DIR="output/guidelines/guidelines_openai_one"
UNIVERSAL_GUIDELINES="src/prompts/guidelines.txt"
REFINE_SYSTEM="src/prompts/p2_response_system_prompt_refinement.txt"

# DNA
DNA_P2_WORK="output/DNA_New_Experiments/p2s/_work_phi4"
DNA_P2_JSONL="output/DNA_New_Experiments/p2s/phi4_p2.jsonl"
DNA_O1="output/DNA_Per_Model_Experiments/helpful_assistant_multimodel/phi4/p1_baseline_outputs.jsonl"
DNA_REFINE_DIR="output/DNA_Per_Model_Experiments/refinement_from_baseline_multimodel/phi4"
DNA_JUDGE_DIR="output/DNA_New_Experiments/evaluation/baseline_vs_refinement_phi4_gemma4_judge"

# LinguaSafe
LS_P2_WORK="output/Linguasafe_Experiments/p2s/_work_phi4"
LS_P2_JSONL="output/Linguasafe_Experiments/p2s/phi4_p2.jsonl"
LS_O1="output/Linguasafe_Experiments/helpful_assistant_multimodel/phi4/p1_baseline_outputs.jsonl"
LS_REFINE_DIR="output/Linguasafe_Experiments/linguasafe_refinement_from_baseline_multimodel/phi4"
LS_JUDGE_DIR="output/Linguasafe_Experiments/evaluation/baseline_vs_refinement_phi4_gemma4_judge"

mkdir -p "$(dirname "$DNA_P2_JSONL")" "$DNA_REFINE_DIR" "$DNA_JUDGE_DIR" \
         "$(dirname "$LS_P2_JSONL")"  "$LS_REFINE_DIR"  "$LS_JUDGE_DIR"

echo "========================================================"
echo "Phi-4 full pipeline"
echo "Job ID: ${SLURM_JOB_ID}"
echo "Node:   $(hostname)"
echo "========================================================"
nvidia-smi --query-gpu=name,memory.total --format=csv,noheader
echo ""

# ══════════════════════════════════════════════════════════════════════════════
# STAGE 1: P1→P2 reframing
# ══════════════════════════════════════════════════════════════════════════════

echo ">>> STAGE 1a: DNA P1→P2 reframing"
if [[ -f "$DNA_P2_JSONL" ]] && [[ $(wc -l < "$DNA_P2_JSONL") -ge 939 ]]; then
    echo "  SKIP: $DNA_P2_JSONL already complete ($(wc -l < "$DNA_P2_JSONL") rows)"
else
    "$PYTHON" scripts/run_p1_to_p2_vllm.py \
        --model                   "$PHI4_PATH" \
        --jsonl-path              "$DNA_JSONL" \
        --language                "en" \
        --guidelines-dir          "$GUIDELINES_DIR" \
        --universal-guidelines    "$UNIVERSAL_GUIDELINES" \
        --output                  "$DNA_P2_JSONL" \
        --tensor-parallel-size    1 \
        --gpu-memory-utilization  0.85 \
        --max-model-len           4096 \
        --temperature             0.3 \
        --max-tokens              512 \
        --batch-size              128
    echo "  Wrote: $DNA_P2_JSONL ($(wc -l < "$DNA_P2_JSONL") rows)"
fi

echo ""
echo ">>> STAGE 1b: LinguaSafe P1→P2 reframing"
if [[ -f "$LS_P2_JSONL" ]] && [[ $(wc -l < "$LS_P2_JSONL") -ge 3267 ]]; then
    echo "  SKIP: $LS_P2_JSONL already complete ($(wc -l < "$LS_P2_JSONL") rows)"
else
    "$PYTHON" scripts/run_p1_to_p2_vllm.py \
        --model                   "$PHI4_PATH" \
        --csv-path                "$LS_CSV" \
        --language                "en" \
        --guidelines-dir          "$GUIDELINES_DIR" \
        --universal-guidelines    "$UNIVERSAL_GUIDELINES" \
        --output                  "$LS_P2_JSONL" \
        --tensor-parallel-size    1 \
        --gpu-memory-utilization  0.85 \
        --max-model-len           4096 \
        --temperature             0.3 \
        --max-tokens              512 \
        --batch-size              128
    echo "  Wrote: $LS_P2_JSONL ($(wc -l < "$LS_P2_JSONL") rows)"
fi

# ── vLLM settings for multi-GPU stages (refinement + judge) ──────────────────
# Stage 1 (P1→P2) uses TP=1 via explicit CLI args; no env override needed.
# Stages 2 and 3 use model_client.py which reads these env vars.
export VLLM_TENSOR_PARALLEL_SIZE=2
export VLLM_GPU_MEMORY_UTILIZATION=0.80
export VLLM_MAX_MODEL_LEN=4096

# ══════════════════════════════════════════════════════════════════════════════
# STAGE 2: Refinement — join O1 + P2, then generate O2
# ══════════════════════════════════════════════════════════════════════════════

run_refinement() {
    local label="$1"
    local o1_file="$2"
    local p2_file="$3"
    local out_dir="$4"

    echo ""
    echo ">>> STAGE 2: Refinement — $label"

    [[ -f "$o1_file" ]] || { echo "  ERROR: O1 not found: $o1_file"; exit 1; }
    [[ -f "$p2_file" ]] || { echo "  ERROR: P2 not found: $p2_file"; exit 1; }

    local refinement_input="${out_dir}/refinement_input.jsonl"
    local refined_file="${out_dir}/baseline_outputs.jsonl"

    # Phase 2a: Join O1 + P2 → refinement_input.jsonl
    if [[ ! -f "$refinement_input" ]] || [[ $(wc -l < "$refinement_input") -lt 10 ]]; then
        echo "  Joining O1 + P2..."
        O1_FILE="$o1_file" P2_FILE="$p2_file" OUT_FILE="$refinement_input" \
        "$PYTHON" - <<'PYEOF'
import json, os
o1_file = os.environ["O1_FILE"]
p2_file = os.environ["P2_FILE"]
out_file = os.environ["OUT_FILE"]

def norm(s): return " ".join((s or "").split()).strip()

with open(o1_file) as f:
    o1_by_id = {str(r["p1_id"]): r for l in f if (r := json.loads(l))}
with open(p2_file) as f:
    p2_by_id = {str(r.get("p1_id", r.get("id",""))): r for l in f if (r := json.loads(l))}

rows = []
for pid, o1 in o1_by_id.items():
    p2r = p2_by_id.get(pid)
    if p2r is None:
        continue
    rows.append({
        "p1_id":          pid,
        "p1":             norm(o1.get("p1","")),
        "p2":             norm(p2r.get("p2", p2r.get("output",""))),
        "baseline_output": norm(o1.get("output","")),
        "category":       o1.get("category", p2r.get("category","")),
        "lang":           o1.get("lang", p2r.get("lang","en")),
        "level":          o1.get("level", p2r.get("level")),
    })

with open(out_file, "w") as f:
    for r in rows: f.write(json.dumps(r, ensure_ascii=False) + "\n")
print(f"Joined {len(rows)} rows → {out_file}")
PYEOF
    else
        echo "  Join already done ($(wc -l < "$refinement_input") rows)"
    fi

    # Phase 2b: Generate O2
    if [[ -f "$refined_file" ]] && [[ $(wc -l < "$refined_file") -ge $(wc -l < "$refinement_input") ]]; then
        echo "  SKIP: refinement already complete ($(wc -l < "$refined_file") rows)"
    else
        echo "  Generating O2..."
        "$PYTHON" src/baselines/generate_p2_controlled_outputs.py \
            --input-jsonl         "$refinement_input" \
            --output-dir          "$out_dir" \
            --system-prompt-file  "$REFINE_SYSTEM" \
            --use-local-model \
            --local-model         "$PHI4_PATH" \
            --temperature         0.3 \
            --max-tokens          2000 \
            --refinement-mode \
            --exit-on-null
        echo "  Wrote: $refined_file"
    fi
}

run_refinement "DNA"        "$DNA_O1" "$DNA_P2_JSONL" "$DNA_REFINE_DIR"
run_refinement "LinguaSafe" "$LS_O1"  "$LS_P2_JSONL"  "$LS_REFINE_DIR"

# ══════════════════════════════════════════════════════════════════════════════
# STAGE 3: Judge — Gemma-4 compares O1 vs O2
# ══════════════════════════════════════════════════════════════════════════════

# Save SLURM-allocated GPUs before setup script overwrites CUDA_VISIBLE_DEVICES
_SLURM_CUDA_DEVICES="${CUDA_VISIBLE_DEVICES:-}"
source scripts/shell/setup_gemma4_vllm_env.sh 2>/dev/null || true
# Restore actual allocated devices so TP matches what SLURM gave us
[[ -n "$_SLURM_CUDA_DEVICES" ]] && export CUDA_VISIBLE_DEVICES="$_SLURM_CUDA_DEVICES"
JUDGE_TP=$(echo "$CUDA_VISIBLE_DEVICES" | tr ',' '\n' | grep -c .)
export VLLM_TENSOR_PARALLEL_SIZE=$JUDGE_TP
export VLLM_GPU_MEMORY_UTILIZATION=0.75
export VLLM_MAX_MODEL_LEN=6144
echo "Judge tensor-parallel-size: $JUDGE_TP (CUDA_VISIBLE_DEVICES=$CUDA_VISIBLE_DEVICES)"

run_judge() {
    local label="$1"
    local refine_dir="$2"
    local judge_dir="$3"
    local refined_file="${refine_dir}/baseline_outputs.jsonl"

    echo ""
    echo ">>> STAGE 3: Judge — $label"
    [[ -f "$refined_file" ]] || { echo "  ERROR: refinement output not found: $refined_file"; exit 1; }

    "$PYTHON" src/evaluation_ranking/evaluate_safety_helpfulness_single_random.py \
        --refinement-jsonl  "$refined_file" \
        --output-dir        "$judge_dir" \
        --evals             all \
        --temperature       0.1 \
        --max-tokens        512 \
        --use-local-model \
        --judge-model       "$GEMMA4_PATH"

    echo "  Results: $judge_dir"
}

run_judge "DNA"        "$DNA_REFINE_DIR" "$DNA_JUDGE_DIR"
run_judge "LinguaSafe" "$LS_REFINE_DIR"  "$LS_JUDGE_DIR"

echo ""
echo "========================================================"
echo "Phi-4 full pipeline complete"
echo "DNA judge:        $DNA_JUDGE_DIR"
echo "LinguaSafe judge: $LS_JUDGE_DIR"
echo "========================================================"
